# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/safety_inventory_db

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# CORS (allowed origins for Expo web app + Railway)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://your-app.up.railway.app

# YOLO Model Configuration
MODEL_CONFIDENCE_THRESHOLD=0.5
MODEL_PATH=./models/yolov8n_safety.tflite

# Roboflow (for dataset download — get your key at https://app.roboflow.com)
ROBOFLOW_API_KEY=your_key_here
